# OttO — Environment Variables Template
# Copy this file to .env and fill in your values.

# Database
POSTGRES_USER=otto
POSTGRES_PASSWORD=otto
POSTGRES_DB=otto
DATABASE_URL=postgresql://otto:otto@localhost:5432/otto

# AI / Voice
OPENAI_API_KEY=sk-...

# LiveKit
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
